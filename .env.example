# Copia este archivo a ".env" en la raíz del proyecto (junto a package.json)
# y rellena los valores. El archivo ".env" no se sube a git.

# Clave de OpenAI (obligatoria para IA completa en el mesero)
OPENAI_API_KEY=

# Modelo de chat (opcional; por defecto en código: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Puerto del API (opcional; por defecto 3041 — evita conflicto si el 3001 lo usa Cursor u otra app)
# PORT=3041

# Palabra de activación del micrófono en el quiosco (opcional; por defecto karen). También editable en Administración → Configuración.
# MESERO_WAKE_WORD=karen

# Cantidad de mesas del local (opcional; por defecto 12). También editable en Administración → Configuración IA.
# MESERO_TABLE_COUNT=12

# Login y perfil AIBox (UI mesero + receptor vía mesero-server)
AIBOX_AUTH_LOGIN_URL=http://37.60.247.8:15000/api/security/auth/login
# AIBOX_AUTH_PROFILE_URL=http://37.60.247.8:15000/api/security/profile
# AIBOX_AUTH_REFRESH_URL=http://37.60.247.8:15000/api/security/auth/refresh-token
# AIBOX_AUTH_EMAIL=
# AIBOX_AUTH_PASSWORD=

# Empresa por defecto (fallback si no hay sesión ni ?companyId=): menú QR, WebSocket, datos legacy migrados
# AIBOX_COMPANY_ID=c3877845-2357-4a38-80cc-ff3314c374c1

# Menú público /menu sin login (opcional; también ?companyId= en la URL del QR)
# VITE_AIBOX_COMPANY_ID=c3877845-2357-4a38-80cc-ff3314c374c1

# Origen API AIBox sin barra final (opcional; por defecto http://37.60.247.8:15000)
# AIBOX_API_ORIGIN=http://37.60.247.8:15000

# TTL caché del menú resuelto desde offerings (ms; opcional; por defecto 60000)
# AIBOX_MENU_CACHE_TTL_MS=60000

# Base SQLite del mesero-server (opcional; por defecto packages/mesero-server/data/mesero.db)
# MESERO_DB_PATH=C:/ruta/mesero.db
# PDF de carta por defecto (se aplica al arrancar a todas las empresas en BD)
# MESERO_DEFAULT_MENU_PDF=/ruta/al/menu.pdf

# Facturación electrónica (módulo facturacion-server, puerto 3042)
# BILLING_URL=http://localhost:3042
# BILLING_PORT=3042
# Token compartido: mesero-server y cualquier API externa (Authorization: Bearer …)
# BILLING_API_KEY=cambiar-por-token-seguro
# BILLING_ENCRYPTION_KEY=clave-larga-para-cifrar-password-del-certificado
# BILLING_REQUIRE_AUTH=true
# BILLING_DATA_DIR=packages/facturacion-server/data