# Ejemplo para VPS con nginx delante de mesero-ia / mesero-server.
# Error típico sin esto: 413 Request Entity Too Large al subir el PDF del menú.
#
# Dentro del server { } o del location que hace proxy_pass a la API:

client_max_body_size 20M;

